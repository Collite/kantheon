# LLM Gateway Configuration
VITE_LLM_GTW_SERVER=localhost
VITE_LLM_GTW_SERVER_PORT=7101
VITE_LLM_GTW_SERVER_PATH=
VITE_LLM_GTW_SERVER_PROTOCOL=http

# MCP ERP Configuration
VITE_MCP_ERP_SERVER=localhost
VITE_MCP_ERP_SERVER_PORT=7151
VITE_MCP_ERP_SERVER_PATH=
VITE_MCP_ERP_SERVER_PROTOCOL=http

# MCP Fuzzy Configuration
VITE_MCP_FUZZY_SERVER=localhost
VITE_MCP_FUZZY_SERVER_PORT=7152
VITE_MCP_FUZZY_SERVER_PATH=
VITE_MCP_FUZZY_SERVER_PROTOCOL=http

# MCP Metadata Configuration
VITE_MCP_METADATA_SERVER=localhost
VITE_MCP_METADATA_SERVER_PORT=7153
VITE_MCP_METADATA_SERVER_PATH=
VITE_MCP_METADATA_SERVER_PROTOCOL=http

# MCP Local Metadata Configuration
VITE_MCP_LOCAL_METADATA_SERVER=localhost
VITE_MCP_LOCAL_METADATA_SERVER_PORT=7199
VITE_MCP_LOCAL_METADATA_SERVER_PATH=
VITE_MCP_LOCAL_METADATA_SERVER_PROTOCOL=http

# ERP Agent Configuration
VITE_ERP_AGENT_SERVER=agent.erp.aip01.dfpartner.cz
VITE_ERP_AGENT_SERVER_PORT=
VITE_ERP_AGENT_SERVER_PROTOCOL=http

# Keycloak Authentication
VITE_KEYCLOAK_URL=http://localhost:8080
VITE_KEYCLOAK_REALM=df-test
VITE_KEYCLOAK_CLIENT_ID=agents-fe

# OpenTelemetry Configuration
VITE_TELEMETRY_ENABLED=false
VITE_OTEL_EXPORTER_OTLP_HOST=localhost
VITE_OTEL_EXPORTER_OTLP_HTTP_PORT=4318
VITE_OTEL_EXPORTER_OTLP_HTTPS_PORT=4318
VITE_OTEL_EXPORTER_OTLP_GRPC_PORT=4317
VITE_AGENTS_FE_OTEL_PROTOCOL=http
VITE_AGENTS_FE_PROTOCOL=http

# Local Development Overrides
VITE_AUTH_ENABLED=true
VITE_HTTPS_ENABLED=false

# UI Theme — PrimeVue Aura preset (Red palette)
# light | dark | auto  (auto follows the OS prefers-color-scheme)
VITE_PRIMEVUE_THEME_MODE=light

# Dockview workspace lockdown (Agent View 3-pane layout)
# strict (v2 default) — disables floating windows + cross-group drag
# relaxed              — opt-in for v2.1+ experimentation
VITE_DOCKVIEW_LOCKDOWN=strict